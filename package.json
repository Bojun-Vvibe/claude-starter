{
  "name": "claude-starter",
  "version": "1.4.3",
  "description": "A beautiful terminal UI for managing Claude Code sessions — start new or resume past conversations",
  "main": "index.js",
  "bin": {
    "claude-starter": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test test.js",
    "test:tui": "node --test test-tui.js",
    "test:all": "node --test test.js test-tui.js",
    "prepublishOnly": "npm run test:all"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tui",
    "terminal",
    "session",
    "resume",
    "ai",
    "ai-native",
    "developer-workflow",
    "local-first",
    "agentic-tooling"
  ],
  "author": "Bojun Chai <just_cbj@sina.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bojun-Vvibe/claude-starter.git"
  },
  "homepage": "https://github.com/Bojun-Vvibe/claude-starter#readme",
  "bugs": {
    "url": "https://github.com/Bojun-Vvibe/claude-starter/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "README.md"
  ],
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0"
  }
